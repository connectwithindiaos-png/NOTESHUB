# In development, Vite defaults to http://localhost:5173
# In production (Vercel), set to your custom domain
VITE_SITE_URL=https://yourdomain.com

# Backend API URL
# In development, defaults to /api/v1 (proxied by Vite to backend)
# In production (Vercel), set to your Render backend URL
VITE_API_URL=https://your-backend.onrender.com/api/v1

# Vite dev server proxy target (development only)
VITE_PROXY_TARGET=http://localhost:5000
